echo "🔍 Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only)
# Check if only playground or .husky files are changed - skip all checks if so
if [ -n "$STAGED_FILES" ]; then
  NON_IGNORED_FILES=$(echo "$STAGED_FILES" | grep -v -E '^(playground/)' || true)
  if [ -z "$NON_IGNORED_FILES" ]; then
    echo "🎮 Only playground files changed - skipping pre-commit checks"
    exit 0
  fi
fi

pnpm vp run task:pre-commit

echo "✅ All pre-commit checks passed!"
